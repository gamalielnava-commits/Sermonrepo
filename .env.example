# ──────────────────────────────────────────────────────────────
# Sermon Pro — variables de entorno
# Copiá este archivo como ".env" y rellená los valores, o pegá
# cada variable en el panel de Railway (Variables).
# ──────────────────────────────────────────────────────────────

# ── REQUERIDAS ──────────────────────────────────────────────
# Tu clave de Google Gemini (gratis): https://aistudio.google.com/apikey
# Se usa para detectar momentos virales, generar títulos, etc.
GEMINI_API_KEY=

# ── OPCIONALES pero recomendadas ────────────────────────────

# Upload-Post: publicar automático en TikTok/Reels/Shorts.
# 10 uploads/mes gratis. https://www.upload-post.com
UPLOAD_POST_API_KEY=

# AWS S3 (para guardar los clips en la nube y la galería pública).
# Tier gratis 5 GB / 12 meses: https://aws.amazon.com/free
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=
AWS_S3_PUBLIC_BUCKET=

# ElevenLabs (doblaje a 30+ idiomas, opcional).
# https://elevenlabs.io
ELEVENLABS_API_KEY=

# fal.ai (solo si vas a usar "AI Shorts" con actores).
# https://fal.ai
FAL_KEY=

# ── DESCARGA DE YOUTUBE (recomendado para cloud/Railway) ────

# Proxy residencial para bajar videos de YouTube sin que te bloqueen con 429.
# Railway y cualquier nube usan IPs de datacenter que YouTube bloquea. Un
# proxy residencial hace pasar el tráfico por IPs domésticas reales.
#
# Webshare.io tiene un plan gratuito (10 proxies rotativos, 1 GB/mes):
#   1. Registrate en https://www.webshare.io (sign up con Google, 30 seg).
#   2. Dashboard → "Proxy" → copiá UNA línea en formato
#      Username:Password:Host:Port (ej "abc123:xyz789:p.webshare.io:80").
#   3. Convertila al formato URL de abajo y pegala acá.
#
# Formato: http://USUARIO:PASSWORD@HOST:PUERTO
YTDLP_PROXY=

# ── AVANZADAS ───────────────────────────────────────────────

# Cuántos trabajos de clipping correr en paralelo.
# Subilo si tu Railway tiene más RAM/CPU.
MAX_CONCURRENT_JOBS=1

# Cookies de YouTube (formato Netscape) — alternativa al proxy para uso
# personal. Para SaaS/comercial usá YTDLP_PROXY en vez de esto.
# YOUTUBE_COOKIES=
